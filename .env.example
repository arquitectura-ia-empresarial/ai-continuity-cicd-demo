# Provider por defecto para ejecución local.
# mock   = modo simulado y reproducible, sin servicios externos.
# ollama = modo real local contra un servidor Ollama.
AI_PROVIDER=mock

# Modelo ligero recomendado para la demo local.
# Alternativas:
# - qwen2.5:0.5b  -> menor consumo, menos calidad.
# - qwen2.5:1.5b  -> equilibrio razonable para demo local.
# - qwen2.5:7b    -> más calidad, más memoria y tiempo.
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://localhost:11434
AI_TIMEOUT_SECONDS=90
